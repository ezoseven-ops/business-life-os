# Copy this to .env and fill in values
# Generate AUTH_SECRET: openssl rand -base64 32

# ─── Database ───
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/blos_dev"

# ─── Auth.js ───
# Generate with: openssl rand -base64 32 (must be ≥32 chars)
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# ─── Google OAuth (login) ───
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Email (Resend) ───
RESEND_API_KEY=""
EMAIL_FROM="noreply@businesslifeos.com"

# ─── File Storage (Cloudflare R2) ───
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="blos-files"
R2_PUBLIC_URL=""

# ─── AI (OpenAI) ───
OPENAI_API_KEY=""

# ─── Telegram ───
TELEGRAM_WEBHOOK_SECRET=""

# ─── WhatsApp ───
WHATSAPP_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""

# ─── Google Calendar OAuth ───
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""

# ─── Sentry ───
SENTRY_DSN=""

# ─── App ───
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
